# ===========================
# Pipeline Pulse v2.0 — .gitignore
# ===========================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
*.egg

# Environment files (never commit real env files)
.env
.env.local
.env.development
.env.production
.env.staging
*.env
!*.env.example

# Credentials and secrets
*.pem
*.key
*.crt
*.pfx
*.p12
sdk_tokens.txt
cookies.txt
*.cookies.txt
token*.txt

# Logs
*.log
logs/
backend.log
server.log
frontend.log

# Testing
coverage/
.coverage
htmlcov/
.pytest_cache/
test-results/
playwright-report/
*.spec.js.snap

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
.cursor/
.augment-*

# Type checking / Linting caches
.mypy_cache/
.ruff_cache/
.eslintcache

# Database
*.db
*.sqlite
*.sqlite3

# AWS / Cloud
.cloudfront-info
.regional-cert-arn
*.tfstate
*.tfstate.backup
.terraform/

# Misc
dist-ssr/
*.local
.cache/

# Claude Code backups
.claude/settings.json.bak
