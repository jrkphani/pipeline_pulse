# ============================================
# Pipeline Pulse v2.0 — Environment Template
# ============================================

# Application
APP_NAME=Pipeline Pulse
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://pipeline_pulse:pipeline_pulse@localhost:5432/pipeline_pulse
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security (JWT — no external OAuth)
SECRET_KEY=generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Currency (SGD base, Currency Freaks API)
BASE_CURRENCY=SGD
CURRENCY_API_KEY=
CURRENCY_API_URL=https://api.currencyfreaks.com/v2.0
CURRENCY_CACHE_DAYS=7

# AWS (ap-southeast-1 — Singapore)
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=pipeline-pulse-documents
AWS_S3_PRESIGNED_URL_EXPIRY_SECONDS=3600
AWS_TEXTRACT_REGION=ap-southeast-1
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Document AI pipeline
DOCAI_MAX_FILE_SIZE_MB=20
DOCAI_MIN_CONFIDENCE_THRESHOLD=0.80

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
