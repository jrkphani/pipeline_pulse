{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "declaration-property-value-disallowed-list": {
      "/color/": ["/#[0-9a-fA-F]{3,8}/", "/rgb\\(/", "/rgba\\(/", "/hsl\\(/"],
      "/background/": ["/#[0-9a-fA-F]{3,8}/", "/rgb\\(/", "/rgba\\(/", "/hsl\\(/"]
    }
  },
  "ignoreFiles": ["**/design-tokens.css", "**/node_modules/**"]
}
